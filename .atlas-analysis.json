  "keyFeatures": [
    "Color-based object detection using OpenCV with HSV segmentation and morphological operations",
    "K-Means clustering with automatic optimal K selection via the elbow method",
    "Average Nearest Neighbor (ANN) spatial analysis for distribution pattern interpretation",
    "GeoJSON export for QGIS compatibility",
    "Session management for centralized storage and retrieval of analysis results",
    "Full analysis pipeline running detect, cluster, and analyze in a single command",
    "Python API for programmatic access to all analysis functionality",
    "Configuration via YAML files or environment variables"
  ],
  "publicApiSurface": [
    "archeo-cluster detect --input-dir <dir> [--color <hex>] [--min-area <n>] [--max-area <n>]",
    "archeo-cluster cluster --input <csv> [--max-k <n>]",
    "archeo-cluster analyze --input <csv>",
    "archeo-cluster pipeline --input-dir <dir> [--color <hex>] [--session <name>]",
    "archeo-cluster sessions [--list] [--latest]",
    "ObjectDetector(config: DetectionConfig)",
    "ObjectDetector.process_directory(input_dir, output_dir) -> BatchDetectionResult",
    "KMeansAnalyzer(config: ClusteringConfig)",
    "KMeansAnalyzer.process_features_csv(input_csv, output_dir) -> BatchClusteringResult",
    "run_spatial_analysis(input_csv, output_dir) -> tuple[DescriptiveStats, list[ANNResult]]",
    "DetectionConfig(target_color, min_area, max_area, kernel_size)",
    "ClusteringConfig(max_k, random_state)",
    "BatchDetectionResult",
    "BatchClusteringResult",
    "ContourFeatures",
    "DetectedObject",
    "ClusterInfo",
    "ElbowResult",
    "PerformanceSummary",
    "StageMetrics"
  ]
